# ============================================================================
# RUST WIPE MANAGER - CONFIGURATION
# Copy this file to config.env and adjust to your needs
# ============================================================================

# --- General paths ---
LGSM_SCRIPT="/home/YOUR_USERNAME/rustserver"
RCON_HOST="127.0.0.1"
RCON_PORT="28016"
RCON_CLI="/home/YOUR_USERNAME/rcon-0.10.3-amd64_linux/rcon"
SERVERFILES_DIR="/home/YOUR_USERNAME/serverfiles"

# --- Server name for messages ---
SERVER_NAME="My Rust Server"
SERVER_TAG="MYSERVER"

# --- Telegram ---
ENABLE_TELEGRAM="true"
TELEGRAM_LOG_LEVEL="full"  # full | success_error | error_only

# --- Daily restart ---
DAILY_RESTART_ENABLED="true"
DAILY_RESTART_COUNTDOWN=1800        # countdown in seconds (30 minutes)
DAILY_RESTART_UPDATE_RUST="true"    # update Rust on daily restart
DAILY_RESTART_UPDATE_OXIDE="true"   # update Oxide on daily restart

# --- Full Wipe ---
FULLWIPE_ENABLED="true"
FULLWIPE_COUNTDOWN=600              # countdown before stop (10 minutes)
FULLWIPE_LONDON_HOUR=19             # hour in London time when Facepunch releases updates
FULLWIPE_PRE_WAIT_MINUTES=30        # how many minutes before update to start preparing
FULLWIPE_UPDATE_WAIT_MAX=7200       # max wait for update (2 hours)
FULLWIPE_UPDATE_CHECK_INTERVAL=120  # check update every 2 minutes

# --- Behavior on Full Wipe day ---
SKIP_DAILY_RESTART_ON_FULLWIPE_DAY="true"

# --- Oxide ---
OXIDE_BACKUP_BEFORE_UPDATE="true"   # backup Managed/ before update
OXIDE_LOAD_TIMEOUT=300              # wait for Oxide to load after start (sec)

# --- Server start ---
SERVER_START_TIMEOUT=600            # max wait for process to appear (sec)

# --- Logs ---
LOG_DIR="/home/YOUR_USERNAME/rust_server/logs"
